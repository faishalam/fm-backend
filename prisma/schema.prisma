generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  salaryMonthly  Float?
  currentSavings Float?
  targetAmount   Float    @default(1000000000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}